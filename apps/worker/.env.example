# ManufactOS AI Worker — Environment Variables
# Copy this file to .env and fill in real values before running.

# OpenAI (used in production for real NLQ; mock mode used by default in dev)
OPENAI_API_KEY=your-openai-api-key-here

# Redis (for Celery broker and result backend)
REDIS_URL=redis://localhost:6379/0

# Core service URL (for fetching live plant data)
CORE_SERVICE_URL=http://localhost:8081

# JWT secret (must match core-service JWT_SECRET)
JWT_SECRET=your-secret-here-must-be-at-least-32-chars-long

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# App
DEBUG=true
LOG_LEVEL=info
